{
  "name": "parqet-cli",
  "version": "1.0.0",
  "description": "CLI for the Parqet portfolio tracker — fetch holdings, performance, and activities",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaeljauk/parqet-cli.git"
  },
  "keywords": [
    "parqet",
    "portfolio",
    "finance",
    "cli",
    "investments"
  ],
  "bin": {
    "parqet": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "scripts/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node && sed -i.bak '1s|.*|#!/usr/bin/env node|' dist/index.js && rm -f dist/index.js.bak && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-typescript https://developer.parqet.com/api-spec/current.json -o src/generated/parqet.d.ts",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "bun run generate && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
