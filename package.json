{
  "name": "parqet-cli",
  "version": "0.1.0",
  "description": "CLI for Parqet portfolio tracker — fetch holdings, performance, and sync snapshots",
  "type": "module",
  "bin": {
    "parqet": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint src/"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
